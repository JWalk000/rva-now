# Copy to supabase/.env.sync (gitignored) and upload via setup-ops-secrets.ps1
# Dashboard: https://supabase.com/dashboard/project/edorsmasowlidwftzqnh/settings/functions

# Required for cron + admin dashboard + manual sync triggers
SYNC_SECRET=generate-a-long-random-string-here
ADMIN_SECRET=generate-another-long-random-string-here

# Posh scraping — comma-separated event URLs (works without API keys)
POSH_EVENT_URLS=https://posh.vip/e/sunset-soul-va-exclusive-sunday-funday-tour

# Eventbrite API (optional — add when you have a private token + org IDs)
# EVENTBRITE_TOKEN=your_private_token
# EVENTBRITE_ORG_IDS=123456789,987654321

# Weekly digest (optional)
# RESEND_API_KEY=re_...
# DIGEST_FROM_EMAIL=digest@yourdomain.com
